# Processador - Variáveis de Ambiente
# Copie para .env e ajuste conforme necessário

# Porta do servidor
PORT=3005

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=processador_dados

# PostgreSQL
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD= 
DB_DATABASE=

# Receptor
RECEPTOR_URL=http://localhost:5000

# Scheduler
SCHEDULER_ENABLE=true
SCHEDULER_INTERVAL_MS=120000

# Log
LOG_LEVEL=debug
