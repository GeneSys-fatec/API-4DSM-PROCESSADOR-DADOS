# Processador - Variáveis de Ambiente
# Copie para .env e ajuste conforme necessário

# Porta do servidor
PORT=3000

# MongoDB
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=processador_dados

# Receptor
RECEPTOR_URL=http://localhost:5000

# Intervalo de sincronização (em milissegundos)
# Padrão: 30 segundos
SINCRONIZAR_INTERVALO_MS=30000

# Log
LOG_LEVEL=debug
